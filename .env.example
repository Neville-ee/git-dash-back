# ─────────────────────────────────────────────────────────────────────────
#  EXAMPLE ONLY — safe to commit. Copy to ".env" for LOCAL development.
#  Put the REAL values in Render's dashboard (Environment tab), NOT in git.
#  The real ".env" is git-ignored on purpose (see .gitignore).
# ─────────────────────────────────────────────────────────────────────────

# Fine-grained GitHub Personal Access Token.
# Private repos need: Repository permissions -> Metadata: Read,
#   Contents: Read, Pull requests: Read. Public repos need no extra perms.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret you invent. Paste the SAME string into the GitHub webhook
# "Secret" field. Used to verify deliveries really came from GitHub.
WEBHOOK_SECRET=choose-a-long-random-string

# Repos to poll, comma-separated "owner/name".
REPOS=your-username/your-repo,your-org/another-repo

# Your dashboard's public URL (the Render static site). Locks down CORS.
# For local dev you can use http://localhost:5173 or leave as *.
ALLOWED_ORIGIN=https://your-frontend.onrender.com

# How often (ms) to poll the GitHub API. 60000 = once a minute.
POLL_INTERVAL=60000

# Render injects PORT automatically. Only set this for local dev.
PORT=10000
